{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alfares.cz/schemas/growth/auth_redirect.initiated.v1.json",
  "title": "Auth redirect initiated",
  "description": "Attribution half of the registration join. Emitted by bazos-service at the moment of the click, BEFORE navigation to auth.alfares.cz - never on the return callback, which is not guaranteed. Joined to auth.user.registered.v1 on correlationId. See D-005.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "producer",
    "workspaceId",
    "correlationId",
    "dataClass",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "const": "growth.auth_redirect.initiated.v1"
    },
    "eventVersion": {
      "type": "integer",
      "const": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "const": "bazos-service"
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "correlationId": {
      "type": "string"
    },
    "causationId": {
      "type": "string",
      "description": "OPTIONAL - root events have none"
    },
    "dataClass": {
      "const": "anonymous"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correlationId",
        "initiatedAt"
      ],
      "properties": {
        "correlationId": {
          "type": "string",
          "description": "Opaque handle echoed back by auth-microservice via the `state` parameter. Join key."
        },
        "gsid": {
          "type": "string",
          "description": "signed session token, raw and UNVERIFIED - growth-core verifies (C-005 s4). Absent is a valid expected case (consent refused / cookie cleared / direct visit) - NOT an error"
        },
        "gsidSource": {
          "enum": [
            "cookie",
            "query"
          ]
        },
        "initiatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
