{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alfares.cz/schemas/growth/lead.created_from_registration.v1.json",
  "title": "Lead created from registration",
  "description": "Anchors LeadQualificationEvent as a post-hoc quality assessment.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "occurredAt",
    "producer",
    "workspaceId",
    "correlationId",
    "dataClass",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "const": "growth.lead.created_from_registration.v1"
    },
    "eventVersion": {
      "type": "integer",
      "const": 1
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "const": "leads-microservice"
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "correlationId": {
      "type": "string"
    },
    "causationId": {
      "type": "string",
      "description": "OPTIONAL - root events have none"
    },
    "dataClass": {
      "const": "personal"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "leadId",
        "userId",
        "sourceService",
        "createdAt"
      ],
      "properties": {
        "leadId": {
          "type": "string"
        },
        "userId": {
          "type": "string",
          "description": "From auth.user.registered.v1. Replaces registrationId, which no service ever minted - see D-005."
        },
        "correlationId": {
          "type": "string",
          "description": "Carried through so a lead can be traced back to its touchpoint. Absent when the registration did not come through a growth landing."
        },
        "sourceService": {
          "const": "auth-microservice"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
